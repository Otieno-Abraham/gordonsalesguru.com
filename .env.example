# Copy this file to .env.local and fill in the real values.
# All NEXT_PUBLIC_* vars are inlined into the static build at build time.

# Gordon's WhatsApp number in full international format, no "+" or spaces.
NEXT_PUBLIC_WHATSAPP_NUMBER=254XXXXXXXXX

# Formspree form ID (https://formspree.io) — the part after /f/.
NEXT_PUBLIC_FORMSPREE_ID=your_formspree_id

# Google Analytics 4 Measurement ID.
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Facebook Pixel ID (silent, ready for ads).
NEXT_PUBLIC_FACEBOOK_PIXEL_ID=your_pixel_id

# Calendly link for showroom-visit bookings.
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/gordonsalesguru

# Canonical site URL (no trailing slash).
NEXT_PUBLIC_SITE_URL=https://gordonsalesguru.com

# Contact email.
NEXT_PUBLIC_EMAIL=consult@gordonsalesguru.com

# Leave blank for the custom domain. Set to "/gordonsalesguru" only when
# hosting on the temporary GitHub project page (gordon.github.io/gordonsalesguru).
NEXT_PUBLIC_BASE_PATH=
